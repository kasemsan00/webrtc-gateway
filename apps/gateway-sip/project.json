{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "gateway-sip",
  "projectType": "application",
  "sourceRoot": "apps/gateway-sip",
  "tags": ["scope:gateway", "type:backend", "lang:go"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/gateway-sip",
        "command": "go run ."
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/gateway-sip",
        "command": "go build -o k2-gateway ."
      },
      "outputs": ["{projectRoot}/k2-gateway"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/gateway-sip",
        "command": "go test ./..."
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/gateway-sip",
        "command": "go mod tidy"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/gateway-sip",
        "command": "docker build -t gateway-sip:local ."
      }
    }
  }
}
