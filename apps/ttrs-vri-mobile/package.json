{
  "name": "ttrs-vri",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "postinstall": "patch-package",
    "android:prebuild": "expo prebuild && node ./scripts/patch-android.js",
    "android": "expo run:android",
    "android:build:online": "eas build -p android --profile preview",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "lint": "expo lint",
    "ios:build:local": "eas build --platform ios --local",
    "ios:build:device": "npx expo run:ios --device"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.5",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/slot": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~55.0.3",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.5",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-router": "~55.0.2",
    "expo-splash-screen": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "lucide-react-native": "^0.563.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-callkeep": "^4.3.16",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-maps": "1.26.20",
    "react-native-mmkv": "^4.1.1",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-size-matters": "^0.4.2",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-webrtc": "^124.0.7",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-incall-manager",
          "react-native-webrtc",
          "react-native-callkeep"
        ]
      }
    }
  },
  "private": true
}
