# Environment Configuration for Softphone Mobile
# 
# IMPORTANT: This file is committed to the repository for simplicity.
# DO NOT store sensitive information (API keys, passwords, etc.) here.
# For local overrides, create .env.local (which is gitignored).

# ==============================================================================
# WebRTC Configuration
# ==============================================================================

# Enable Picture-in-Picture (PiP) mode for iOS video calls
# When enabled, video continues in a floating window when app goes to background
# 
# Default: false
# 
# Set to false to disable PiP (call continues in background with audio only)
EXPO_PUBLIC_PIP_ENABLED=false

# Video bitrate limit in kilobits per second (kbps)
# Controls both incoming (via SDP b=AS) and outgoing (via RTCRtpSender) video bandwidth
# 
# Default: 1500
# Range: 50-10000 (recommended: 500-3000)
# 
# Examples:
#   - 500:  Lower quality, saves bandwidth (mobile data-friendly)
#   - 1500: Balanced quality and bandwidth (default)
#   - 3000: Higher quality, requires stable connection

EXPO_PUBLIC_GATEWAY_SERVER=wss://k2-gateway.kasemsan.com/ws
EXPO_PUBLIC_VIDEO_BITRATE_KBPS=3000
