[agi-send-event]
exten => _.,1,NoOp(agi send event)
same => n,NoOp(${EXTEN})
same => n,ExecIf($["${DB(VRS_VARIABLE/${USER_ID}/agent_ring_num)}" = ""]?Set(agent_num=${DB(AMPUSER/${QAGENT}/cidnum)}):Set(agent_num=${DB(VRS_VARIABLE/${USER_ID}/agent_ring_num)}))
same => n,ExecIf($["${DB(VRS_VARIABLE/${USER_ID}/agent_ring_name)}" = ""]?Set(agent_name=${DB(AMPUSER/${QAGENT}/cidname)}):Set(agent_name=${DB(VRS_VARIABLE/${USER_ID}/agent_ring_name)}))
same => n,AGI(${VRS_AGI_DIR}/agi_get_username.php,${agent_num})

same => n,Set(event=${EXTEN})
same => n,Set(uniqueid=${USER_UNIQUEID})
same => n,Set(source_number=${USER_ID})
same => n,Set(source_name=${USER_NAME})
same => n,Set(destination_number=${USER_OUT_MAPPING})
same => n,Set(agent_number=${agent_num})
same => n,Set(agent_name=${agent_name})
same => n,Set(agent_username=${AGENT_USERNAME})
same => n,Set(source_type=${USER_SOURCE_TYPE})
same => n,Set(call_type=${USER_CALL_TYPE})
same => n,Set(log_type=${USER_PRIORITY_TYPE})
same => n,Set(service_group=${USER_GROUP_TYPE})
same => n,Set(card_id=)

same => n(ase_1),AGI(${VRS_AGI_DIR}/curl_send_event.php)
same => n,Return()