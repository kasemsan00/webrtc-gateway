# TURN Server Configuration (for WebRTC)
TURN_SERVER=turn:turn.ttrs.or.th:3478?transport=udp
TURN_USERNAME=turn01
TURN_PASSWORD=Test1234

# Local IP to bind SIP listeners (Optional - prevents IPv6 Via headers)
# Use specific IPv4 address (e.g., 192.168.1.100, 100.100.1.100) to force IPv4
# Default: 0.0.0.0 (all interfaces, but may use IPv6 on Windows)
# Find your local IP: ipconfig (Windows) or ifconfig/ip addr (Linux)
SIP_LOCAL_IP=0.0.0.0

# SIP listener transports
# TCP listener is enabled by default and is required for providers/proxies using TCP/TLS upstream handoff
# UDP listener is disabled by default; enable when your provider/client sends INVITE to gateway over UDP
SIP_LISTEN_TCP=true
SIP_LISTEN_UDP=false

# Public IP (Optional - for NAT traversal)
# If gateway is behind NAT, set this to your public IP address
# Asterisk will use this IP to send SIP/RTP packets back to gateway
# Leave empty to use local IP address (auto-detected)
SIP_PUBLIC_IP=49.49.54.94

# API Server Configuration (for HTTP/WebSocket signaling)
# Port for the HTTP/WebSocket API server
API_PORT=8080
# Enable WebSocket endpoint (/ws) for real-time signaling
API_ENABLE_WS=true
# Enable REST API endpoints (/api/*)
API_ENABLE_REST=true
# CORS allowed origins (comma-separated, use * for all)
API_CORS_ORIGINS=*

# Debug Configuration
# Enable WebSocket debug logging (ping/pong messages, connection events)
# Set to true to see heartbeat logs for troubleshooting connection issues
DEBUG_WEBSOCKET=false

# Enable TURN/ICE debug logging (ICE candidates, selected candidate pair)
# Set to true to see detailed ICE candidate discovery and selected path information
# Useful for verifying that WebRTC connections are using TURN relay servers
# Logs include: candidate types (host/srflx/relay), addresses, ports, and selected pair details
DEBUG_TURN=false

# Enable SIP MESSAGE debug logging (show full MESSAGE request/response details)
# Set to true to see complete SIP MESSAGE headers and body for troubleshooting
DEBUG_SIP_MESSAGE=false

# Enable SIP INVITE debug logging (show full INVITE headers)
# Set to true to dump full INVITE requests (useful for Record-Route debugging)
DEBUG_SIP_INVITE=false

# Delay in milliseconds before sending PLI on @switch message (default: 1000)
# When receiving @switch:queueNumber|agentUsername message, wait this many ms before requesting keyframe
# Set to 0 to disable delay
SWITCH_PLI_DELAY_MS=1000

# RTP Configuration (for media streams)
# UDP port range for RTP audio/video streams
# Default: 10500-10600 (supports ~25 concurrent video calls, ~100 audio-only calls)
RTP_PORT_MIN=10500
RTP_PORT_MAX=10600
# RTP packet buffer size in bytes (default: 16384 for Android mobile compatibility)
# Android WebRTC can send packets at higher rates. Increase if you experience blackscreen on Android
RTP_BUFFER_SIZE=16384

# Use RTP/AVPF profile for audio with RTCP feedback (default: false)
# When enabled, SDP audio m-line will use RTP/AVPF instead of RTP/AVP
# This enables RTCP feedback mechanisms for audio stream
# Requires SIP endpoint (Asterisk/Linphone) to support AVPF for audio
# For Asterisk chan_sip: may require avpf=yes in peer config (depending on version)
# Set to true if your SIP server supports AVPF for better audio quality/recovery
SIP_AUDIO_USE_AVPF=true

# Use RTP/AVPF profile for video with RTCP feedback (PLI/FIR/NACK) (default: false)
# When enabled, SDP video m-line will use RTP/AVPF instead of RTP/AVP and include a=rtcp-fb attributes
# This enables Picture Loss Indication (PLI), Full Intra Request (FIR), and Negative Acknowledgments (NACK)
# Requires SIP endpoint (Asterisk/Linphone) to support AVPF and RTCP feedback
# Set to true if your SIP server and clients support AVPF for better keyframe recovery
SIP_VIDEO_USE_AVPF=true

# Database (required for trunk resolve/create)
DB_ENABLE=true
# Example Postgres DSN: postgres://user:pass@host:5432/dbname?sslmode=disable
DB_DSN=postgres://user:pass@localhost:5432/k2gateway?sslmode=disable

# SIP Trunk (auto-register from DB)
SIP_TRUNK_ENABLE=true
SIP_TRUNK_LEASE_TTL_SECONDS=60
SIP_TRUNK_LEASE_RENEW_INTERVAL_SECONDS=20
SIP_TRUNK_REGISTER_TIMEOUT_SECONDS=10

# Gateway identity / discovery
GATEWAY_INSTANCE_ID=dev-instance-1
# Public WS URL for redirect (e.g. wss://your-host/ws)
GATEWAY_PUBLIC_WS_URL=
